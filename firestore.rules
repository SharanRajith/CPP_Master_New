rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth.token.email in [
        'sharanrajithk@gmail.com',
        'madhurahegde475@gmail.com'
      ];
    }

    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
                   (request.auth.uid == userId || isAdmin());

      match /notifications/{notifId} {
        allow read:   if request.auth.uid == userId;
        allow create: if isAdmin();
        allow update: if request.auth.uid == userId;
        allow delete: if request.auth.uid == userId || isAdmin();
      }
    }

    match /discussions/{lessonId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /discussions/{lessonId}/comments/{commentId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin() || request.auth.uid == resource.data.uid;
    }

    match /announcements/{annId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow create: if request.auth != null;
      allow read:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

  }
}
